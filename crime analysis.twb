      <column caption='Hour' datatype='integer' name='[Calculation_731834979710611456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [Date])' />
      </column>
      <column caption='Day of Week' datatype='string' name='[Calculation_731834979711660033]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [Date])' />
      </column>
      <column caption='Time Block' datatype='string' name='[Calculation_731834979713966082]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, [Date]) &gt;= 5 AND DATEPART(&apos;hour&apos;, [Date]) &lt; 12 THEN &quot;Morning&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [Date]) &gt;= 12 AND DATEPART(&apos;hour&apos;, [Date]) &lt; 17 THEN &quot;Afternoon&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [Date]) &gt;= 17 AND DATEPART(&apos;hour&apos;, [Date]) &lt; 21 THEN &quot;Evening&quot;&#13;&#10;ELSE &quot;Night&quot;&#13;&#10;END' />
      </column>
      <column caption='Crime count' datatype='integer' name='[Calculation_731834979714097155]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ID])' />
      </column>
      <column caption='Percent of total' datatype='real' name='[Calculation_731834979742273540]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Case Number]) / TOTAL(COUNTD([Case Number]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='% Domestic' datatype='real' name='[Calculation_731834979752976391]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(INT([Domestic]))' />
      </column>
